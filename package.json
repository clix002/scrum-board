{
	"name": "scrum-board",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "biome check --write .",
		"lint:fix": "biome check --write .",
		"check-types": "turbo run check-types",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"husky": "^9.1.7",
		"turbo": "^2.9.16",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
